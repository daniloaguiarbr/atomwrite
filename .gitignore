# ── Build artifacts ──
/target/
**/*.rs.bk

# ── IDE and editor ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Environment and secrets ──
.env
.env.*
*.pem
*.key
*.p12
*.pfx

# ── AI tooling and project docs (not versioned) ──
.claude/
docs_prd/
docs_rules/
CLAUDE.md
AGENTS.pt-BR.md

