{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeleteOutput",
  "description": "NDJSON output for a completed delete operation.",
  "type": "object",
  "properties": {
    "bytes": {
      "description": "File size in bytes before deletion.",
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "checksum_before": {
      "description": "BLAKE3 checksum before deletion.",
      "type": "string"
    },
    "elapsed_ms": {
      "description": "Duration in milliseconds.",
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "path": {
      "description": "Deleted file path.",
      "type": "string"
    },
    "type": {
      "description": "Event type discriminator.",
      "type": "string"
    }
  },
  "required": [
    "type",
    "path",
    "bytes",
    "checksum_before",
    "elapsed_ms"
  ]
}
