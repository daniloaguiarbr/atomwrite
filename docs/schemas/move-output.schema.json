{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MoveOutput",
  "description": "NDJSON output for a completed move operation.",
  "type": "object",
  "properties": {
    "atomic": {
      "description": "Whether the operation was atomic.",
      "type": "boolean"
    },
    "backup_path": {
      "description": "Path to backup file, if created.",
      "type": [
        "string",
        "null"
      ]
    },
    "bytes": {
      "description": "File size in bytes.",
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "checksum": {
      "description": "BLAKE3 checksum.",
      "type": "string"
    },
    "cross_device": {
      "description": "Whether a cross-device copy was needed.",
      "type": "boolean"
    },
    "elapsed_ms": {
      "description": "Duration in milliseconds.",
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "source": {
      "description": "Source path.",
      "type": "string"
    },
    "target": {
      "description": "Target path.",
      "type": "string"
    },
    "type": {
      "description": "Event type discriminator.",
      "type": "string"
    }
  },
  "required": [
    "type",
    "source",
    "target",
    "bytes",
    "checksum",
    "cross_device",
    "atomic",
    "elapsed_ms"
  ]
}
